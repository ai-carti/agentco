# AgentCo — Environment Variables
# Copy to .env and fill in your values.
# Never commit .env to version control.

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (ALEX-TD-001 / ALEX-TD-007)
# In production: set to your frontend URL, e.g. https://agentco.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret key for JWT signing. Generate with: openssl rand -hex 32
SECRET_KEY=

# JWT access token expiry in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default) — path relative to backend working directory
AGENTCO_DB_URL=sqlite:///./agentco.db

# Railway deployment: use persistent volume to avoid data loss on restart.
# 1. Create a Volume in Railway dashboard (mount path: /data)
# 2. Set: AGENTCO_DB_URL=sqlite:////data/agentco.db
# See docs/DEPLOY-TOKEN-GUIDE.md for full instructions.

# Memory/vector store DB
AGENTCO_MEMORY_DB=./agentco_memory.db

# ── LLM API Keys ──────────────────────────────────────────────────────────────
# LiteLLM reads these automatically — set at least one.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: override default models
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── Encryption ────────────────────────────────────────────────────────────────
# Fernet key for encrypting stored secrets. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Orchestration limits ──────────────────────────────────────────────────────
MAX_AGENT_ITERATIONS=20
MAX_RUN_COST_USD=1.0
MAX_RUN_TOKENS=100000

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
