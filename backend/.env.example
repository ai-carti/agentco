# AgentCo Backend — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# ── Database ──────────────────────────────────────────────────────────────────
# DATABASE_URL: new standard variable (ALEX-POST-001).
# SQLite by default — switch to Postgres after demo with one env change.
DATABASE_URL=sqlite:///./agentco.db
# For production: DATABASE_URL=postgresql://user:pass@host:5432/agentco
# Postgres sync engine: pip install "agentco[postgres]"   (psycopg2-binary)
# Postgres async engine: pip install "agentco[async]"      (asyncpg + sqlalchemy[asyncio])
# ALEX-POST-010: postgresql:// URLs are auto-converted to postgresql+asyncpg://
# for async FastAPI endpoints when using get_async_session() dependency.

# Legacy variable (still supported; DATABASE_URL takes priority if both set)
AGENTCO_DB_URL=sqlite:///./agentco.db

# File path for checkpointer (LangGraph) and memory (sqlite-vec)
# On Railway with persistent volume mounted at /app/data:
#   DATABASE_URL=sqlite:////app/data/agentco.db
AGENTCO_DB_PATH=./agentco.db

# Memory DB can be separate file or same as AGENTCO_DB_PATH
# If not set, defaults to AGENTCO_DB_PATH
# AGENTCO_MEMORY_DB=/app/data/agentco_memory.db

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# ── Encryption ────────────────────────────────────────────────────────────────
# Fernet key for encrypting user API keys (credentials). REQUIRED in production.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: changing this key invalidates all previously encrypted credentials.
ENCRYPTION_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Horizontal scaling (ALEX-POST-002) ───────────────────────────────────────
# Optional: Redis pub/sub EventBus for multi-worker deployments.
# If not set, falls back to in-process asyncio.Queue (single worker only).
# REDIS_URL=redis://localhost:6379/0

# ── Rate limiting (ALEX-POST-003, ALEX-POST-012) ─────────────────────────────
# Redis-backed rate limit storage for multi-replica Railway deployments (ALEX-POST-012).
# If set, slowapi uses Redis storage so rate limit counters persist across restarts
# and are shared between multiple workers/replicas.
# If not set, falls back to in-memory storage (resets on restart, single-worker only).
# REDIS_URL=redis://localhost:6379/0
# For Railway: set REDIS_URL to your Redis plugin URL (e.g. redis://default:...@redis.railway.internal:6379)
#
# ALEX-TD-171: complete list of all rate limit env vars (previously undocumented).
# All values below are defaults. Uncomment and adjust for your environment.
#
# Auth endpoints
# RATE_LIMIT_AUTH_REGISTER=5/minute
# RATE_LIMIT_AUTH_LOGIN=10/minute
# RATE_LIMIT_AUTH_ME=120/minute
#
# Runs
# RATE_LIMIT_RUN=10/minute
# RATE_LIMIT_CREATE_RUN=20/minute
# RATE_LIMIT_RUNS_READ=120/minute
#
# Companies
# RATE_LIMIT_COMPANIES=5/hour
# RATE_LIMIT_COMPANIES_READ=120/minute
#
# Agents
# RATE_LIMIT_AGENTS=20/hour
# RATE_LIMIT_AGENTS_READ=120/minute
# RATE_LIMIT_AGENTS_TREE=30/minute
#
# Tasks
# RATE_LIMIT_TASKS_CREATE=60/minute
# RATE_LIMIT_TASKS_MUTATE=120/minute
# RATE_LIMIT_TASKS_READ=120/minute
#
# Credentials & LLM providers
# RATE_LIMIT_CREDENTIALS=30/minute
# RATE_LIMIT_VALIDATE_KEY=5/minute
#
# Agent library
# RATE_LIMIT_LIBRARY_READ=60/minute
# RATE_LIMIT_SAVE_LIBRARY=10/minute
# RATE_LIMIT_FORK=20/minute
#
# Templates
# RATE_LIMIT_TEMPLATES_READ=60/minute
# RATE_LIMIT_TEMPLATES_CREATE=5/hour
#
# MCP servers
# RATE_LIMIT_MCP_CREATE=20/minute
# RATE_LIMIT_MCP_DELETE=20/minute
# RATE_LIMIT_MCP_READ=120/minute
#
# Memory endpoint
# RATE_LIMIT_MEMORY=60/minute

# ── Orchestration limits ──────────────────────────────────────────────────────
# Max LLM iterations per agent run (prevents infinite loops).
# MAX_AGENT_ITERATIONS=20
# Max cost in USD before run is aborted.
# MAX_RUN_COST_USD=1.0
# Max tokens consumed before run is aborted.
# MAX_RUN_TOKENS=100000
# Max run wall-clock timeout in seconds (asyncio.wait_for wrapping ainvoke).
# MAX_RUN_TIMEOUT_SEC=600
# Per-call LLM timeout in seconds (asyncio.wait_for wrapping litellm.acompletion).
# LLM_CALL_TIMEOUT_SEC=120
# Timeout for POST /auth/llm/validate-key real LLM probe in seconds.
# VALIDATE_KEY_TIMEOUT_SEC=30

# ── WebSocket limits ──────────────────────────────────────────────────────────
# Max concurrent WebSocket connections per authenticated user.
# Prevents DoS where a single user exhausts server memory with thousands of WS connections.
# MAX_WS_CONNECTIONS_PER_USER=5

# NOTE (ALEX-TD-184): slowapi does not support @limiter.limit on WebSocket endpoints.
# Each WS connection attempt (even with an invalid token) creates a DB session and runs
# an ownership-check SELECT. There is currently NO rate limit on WS connection attempts per IP.
# Risk: unbounded polling at 1K+ attempts/sec → DB load.
# Mitigation roadmap: implement in-memory per-IP counter (window=60s) or pre-auth HTTP handshake.

# ── Run retry configuration ───────────────────────────────────────────────────
# Max retry attempts for a failed agent run (per-execute_run call, not per-agent-step).
# ALEX-TD-206: RUN_MAX_RETRIES controls how many times the entire execute_run() is retried
# on transient failure (e.g. LLM timeout, network error). It is NOT a per-agent-step retry —
# the graph itself has no per-step retry; the whole run restarts from the beginning each time.
# RUN_MAX_RETRIES=3
# Base delay in seconds between retries (exponential backoff with jitter).
# RUN_RETRY_BASE_DELAY=1.0

# ── Structured logging (ALEX-POST-004) ───────────────────────────────────────
# Optional: OpenTelemetry OTLP endpoint for distributed tracing.
# OTLP_ENDPOINT=http://otel-collector:4317
LOG_LEVEL=INFO

# ── LangGraph checkpointing (ALEX-POST-005) ──────────────────────────────────
# Path to SQLite file for LangGraph run checkpoints.
# CHECKPOINT_DB_PATH=data/checkpoints.db
