# AgentCo Backend — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# ── Database ──────────────────────────────────────────────────────────────────
# SQLAlchemy URL for main DB (companies, agents, tasks, runs)
AGENTCO_DB_URL=sqlite:///./agentco.db

# File path for checkpointer (LangGraph) and memory (sqlite-vec)
# On Railway with persistent volume mounted at /app/data:
#   AGENTCO_DB_PATH=/app/data/agentco.db
AGENTCO_DB_PATH=./agentco.db

# Memory DB can be separate file or same as AGENTCO_DB_PATH
# If not set, defaults to AGENTCO_DB_PATH
# AGENTCO_MEMORY_DB=/app/data/agentco_memory.db

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
